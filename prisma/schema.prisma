// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  VENDEDOR
  AUDITOR
}

model User {
  id       Int     @id @default(autoincrement())
  name     String
  lastName String?
  email    String  @unique
  password String
  role     Role    @default(VENDEDOR)
  ventas   Venta[]
}

model Product {
  id           Int             @id @default(autoincrement())
  nameProduct  String
  price        Float
  stock        Int             @default(0)
  category     Category        @relation(fields: [categoryId], references: [id])
  categoryId   Int
  detalleVenta Detalle_venta[]
  providers    Provider[]
}

model Provider {
  id       Int       @id @default(autoincrement())
  name     String
  phone    String?
  email    String?
  products Product[]
}

model Detalle_venta {
  id              Int     @id @default(autoincrement())
  productId       Int
  product         Product @relation(fields: [productId], references: [id])
  ventaId         Int
  venta           Venta   @relation(fields: [ventaId], references: [id])
  cantidadVendida Float
  precioVendido   Float
}

model Venta {
  id           Int             @id @default(autoincrement())
  fecha        DateTime        @default(now())
  saldoTotal   Float
  status       String          @default("ACTIVA") // Todas la ventas se crean activa, solo cambia cuando se anula por modidicación
  isContado    Boolean         @default(true)
  clientId     Int
  client       Client          @relation(fields: [clientId], references: [id])
  userId       Int
  user         User            @relation(fields: [userId], references: [id])
  detalleVenta Detalle_venta[]
}

model Category {
  id          Int       @id @default(autoincrement())
  name        String
  description String?
  products    Product[]
}

model Credit {
  id           Int      @id @default(autoincrement())
  totalCredit  Float
  fecha        DateTime @default(now())
  clientId     Int
  clientCretit Client   @relation(fields: [clientId], references: [id])
}

model Client {
  id           Int      @id @default(autoincrement())
  name         String
  phone        String?
  email        String?
  document     String   @unique
  tipoDocument String
  ventas       Venta[]
  credits      Credit[]
}
